{
  "name": "cosmere-combat-tracker",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "ng serve --proxy-config proxy.conf.json",
    "start:backend": "tsx watch backend/src/server.ts",
    "build": "ng build",
    "build:backend": "tsc -p backend/tsconfig.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "21.2.2",
    "@angular/compiler": "21.2.2",
    "@angular/core": "21.2.2",
    "@angular/forms": "21.2.2",
    "@angular/platform-browser": "21.2.2",
    "@angular/router": "21.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
